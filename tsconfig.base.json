{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,

    /* Common ergonomics */
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "utils/*": ["utils/*"],
      "logic/*": ["src/logic/*"]
    }
  }
}
